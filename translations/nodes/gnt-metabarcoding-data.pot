msgstr ""

#. type: Title ===
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:71
#, no-wrap
msgid "Decoding metabarcoding"
msgstr ""

#. type: delimited block =
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:76
msgid ""
"For this activity, group members will look at practical applications of "
"metabarcoding for biodiversity monitoring and compare strengths and "
"limitations of metabarcoding versus traditional methods."
msgstr ""

#. type: delimited block =
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:80
msgid "Appoint a recorder and a presenter."
msgstr ""

#. type: delimited block =
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:81
msgid "Select a scenario."
msgstr ""

#. type: delimited block =
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:82
msgid "Brainstorm answers to questions."
msgstr ""

#. type: delimited block =
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:83
msgid "Report back across groups."
msgstr ""

#. type: delimited block =
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:85
#, no-wrap
msgid "*Scenarios*\n"
msgstr ""

#. type: delimited block *
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:88
msgid "_Freshwater Monitoring_"
msgstr ""

#. type: delimited block *
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:90
#, no-wrap
msgid "*Scenario*: A national park authority wants to monitor aquatic invertebrate diversity in rivers to assess ecosystem health.\n"
msgstr ""

#. type: delimited block *
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:92
#, no-wrap
msgid "*Traditional approach*: Kick-sampling, expert ID under microscope.\n"
msgstr ""

#. type: delimited block *
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:94
#, no-wrap
msgid "*Task*: Consider how metabarcoding could complement or replace this, what data it generates, and why it matters.\n"
msgstr ""

#. type: delimited block *
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:98
msgid "_Soil Microbial Communities_"
msgstr ""

#. type: delimited block *
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:100
#, no-wrap
msgid "*Scenario*: An agricultural research institute is studying soil microbes that contribute to nitrogen fixation and drought tolerance in crops.\n"
msgstr ""

#. type: delimited block *
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:102
#, no-wrap
msgid "*Traditional approach*: Culture-based methods.\n"
msgstr ""

#. type: delimited block *
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:104
#, no-wrap
msgid "*Task*: Discuss how metabarcoding improves coverage of microbial diversity and generates data usable for agri-biodiversity planning.\n"
msgstr ""

#. type: delimited block *
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:108
msgid "_Invasive Species Detection_"
msgstr ""

#. type: delimited block *
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:110
#, no-wrap
msgid "*Scenario*: A port authority is monitoring ballast water for invasive species introduction.\n"
msgstr ""

#. type: delimited block *
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:112
#, no-wrap
msgid "*Traditional approach*: Manual sampling and visual identification.\n"
msgstr ""

#. type: delimited block *
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:114
#, no-wrap
msgid "*Task*: Explore how metabarcoding could provide faster, broader detection.\n"
msgstr ""

#. type: delimited block *
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:118
msgid "_Pollinator Communities_"
msgstr ""

#. type: delimited block *
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:120
#, no-wrap
msgid "*Scenario*: A conservation NGO wants to identify pollinator species visiting crops in fragmented landscapes.\n"
msgstr ""

#. type: delimited block *
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:122
#, no-wrap
msgid "*Traditional approach*: Manual observation and specimen collection.\n"
msgstr ""

#. type: delimited block *
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:124
#, no-wrap
msgid "*Task*: Consider DNA metabarcoding of pollen loads as a method for detecting plant–pollinator networks.\n"
msgstr ""

#. type: Plain text
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:127
#, no-wrap
msgid "*Questions*\n"
msgstr ""

#. type: Plain text
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:129
msgid "Application: How could metabarcoding be applied in this scenario?"
msgstr ""

#. type: Plain text
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:130
msgid ""
"Comparison: Why might metabarcoding be better suited (or not) compared to "
"traditional methods?"
msgstr ""

#. type: Plain text
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:131
msgid ""
"Data Types: What kinds of biodiversity data would this generate (e.g., "
"species occurrence, relative abundance, community composition, functional "
"diversity)?"
msgstr ""

#. type: Plain text
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:132
msgid ""
"GBIF Relevance: How could this data be mobilized to GBIF, and who would "
"benefit from its use?"
msgstr ""

#. type: Plain text
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:133
msgid ""
"Challenges: What are potential obstacles (technical, capacity, data "
"standards, cost, reference library gaps)?"
msgstr ""

