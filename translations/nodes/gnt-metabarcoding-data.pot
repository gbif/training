msgstr ""

#. type: delimited block =
#: en/nodes/modules/ROOT/pages/gnt-metabarcoding-data.adoc:59
msgid ""
"This presentation introduces the training topic and provides a basis for "
"understanding DNA metabarcoding in biodiversity research."
msgstr ""

