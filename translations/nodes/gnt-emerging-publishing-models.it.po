msgstr ""

#. type: delimited block =
#: en/nodes/modules/ROOT/pages/gnt-emerging-publishing-models.adoc:94
msgid "Trainer"
msgstr ""

#. type: delimited block =
#: en/nodes/modules/ROOT/pages/gnt-emerging-publishing-models.adoc:95
msgid "Beedrill_01"
msgstr ""

#. type: delimited block =
#: en/nodes/modules/ROOT/pages/gnt-emerging-publishing-models.adoc:96
msgid "Beedrill_02"
msgstr ""

#. type: delimited block =
#: en/nodes/modules/ROOT/pages/gnt-emerging-publishing-models.adoc:97
msgid "Combee"
msgstr ""

#. type: delimited block =
#: en/nodes/modules/ROOT/pages/gnt-emerging-publishing-models.adoc:98
msgid "Cutiefly"
msgstr ""

#. type: delimited block =
#: en/nodes/modules/ROOT/pages/gnt-emerging-publishing-models.adoc:99
msgid "Butterfree"
msgstr ""

#. type: delimited block =
#: en/nodes/modules/ROOT/pages/gnt-emerging-publishing-models.adoc:100
msgid "Pikachu"
msgstr ""

#. type: delimited block =
#: en/nodes/modules/ROOT/pages/gnt-emerging-publishing-models.adoc:102
msgid "Step 2: Each Pokémon has a set of information (provided on white cards).  The Pokémon and the Trainer(s) should determine which tables (the colored cards) will be used to represent the information."
msgstr ""

#. type: delimited block =
#: en/nodes/modules/ROOT/pages/gnt-emerging-publishing-models.adoc:104
msgid "Step 3: All the cards can be glued to the provided sheets of paper."
msgstr ""

#. type: delimited block =
#: en/nodes/modules/ROOT/pages/gnt-emerging-publishing-models.adoc:106
msgid "Step 4: Once the information and tables are arranged, the tables can be joined."
msgstr ""

#. type: delimited block =
#: en/nodes/modules/ROOT/pages/gnt-emerging-publishing-models.adoc:108
msgid "Step 5: Remember to add your table name to your completed mapping."
msgstr ""

#. type: delimited block =
#: en/nodes/modules/ROOT/pages/gnt-emerging-publishing-models.adoc:110
