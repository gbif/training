msgstr "&nbsp;"

#. type: Title =
#: en/data-use/modules/ROOT/pages/navigation.adoc:1
#, no-wrap
msgid "Navigating this course"
msgstr "Navegar este curso"

#. type: Title ==
#: en/data-use/modules/ROOT/pages/navigation.adoc:3
#, no-wrap
msgid "Left navigation"
msgstr "Navegación izquierda"

#. type: Plain text
#: en/data-use/modules/ROOT/pages/navigation.adoc:6
msgid "You will find the course navigation on the left side of the page. Some of the menu items expand/collapse."
msgstr "Encontrará la navegación del curso en la parte izquierda de la página. Algunos de los elementos del menú se expanden/contraen."

#. type: Target for macro image
#: en/data-use/modules/ROOT/pages/navigation.adoc:7
#, no-wrap
msgid "data-use::course-left-nav.png"
msgstr "data-use::course-left-nav.png"

#. type: Title ==
#: en/data-use/modules/ROOT/pages/navigation.adoc:11
#, no-wrap
msgid "Right navigation"
msgstr "Navegación derecha"

#. type: Plain text
#: en/data-use/modules/ROOT/pages/navigation.adoc:14
msgid "You will find individual page contents on the right side of the page."
msgstr "Encontrará el contenido de cada página a la derecha."

#. type: Target for macro image
#: en/data-use/modules/ROOT/pages/navigation.adoc:15
#, no-wrap
msgid "epn::course-right-nav.png"
msgstr "epn::course-right-nav.png"

#. type: Title ==
#: en/data-use/modules/ROOT/pages/navigation.adoc:19
#, no-wrap
msgid "Bottom navigation"
msgstr "Navegación inferior"

#. type: Plain text
#: en/data-use/modules/ROOT/pages/navigation.adoc:22
msgid "At the bottom of each page you will find forward and back buttons to move you through the content."
msgstr "En la parte inferior de cada página encontrará botones para avanzar y retroceder por el contenido."

#. type: Target for macro image
#: en/data-use/modules/ROOT/pages/navigation.adoc:23
#, no-wrap
msgid "epn::course-bottom-nav.png"
msgstr "epn::course-bottom-nav.png"

#. type: Title ==
#: en/data-use/modules/ROOT/pages/navigation.adoc:27
#, no-wrap
msgid "Action icons"
msgstr "Iconos de acción"

#. type: Plain text
#: en/data-use/modules/ROOT/pages/navigation.adoc:30
msgid "The course is comprised of modules. Each modules contains a series of actions for you to complete. This may include reading assignments, videos to watch, notes to take, and exercises to complete."
msgstr "El curso se compone de módulos. Cada módulo contiene una serie de acciones que debe completar. Puede incluir tareas de lectura, vídeos que ver, notas que tomar y ejercicios que realizar."

#. type: Plain text
#: en/data-use/modules/ROOT/pages/navigation.adoc:32
msgid "Look for the following icons indicating you need to take action:"
msgstr "Busque los siguientes iconos que le indican que debe actuar:"

#. type: Plain text
#: en/data-use/modules/ROOT/pages/navigation.adoc:35
msgid "Reading assignments"
msgstr "Tareas de lectura"

#. type: Plain text
#: en/data-use/modules/ROOT/pages/navigation.adoc:38
msgid "Watch a video"
msgstr "Ver un vídeo"

#. type: Plain text
#: en/data-use/modules/ROOT/pages/navigation.adoc:41
msgid "Check your understanding"
msgstr "Compruebe su comprensión"

#. type: Plain text
#: en/data-use/modules/ROOT/pages/navigation.adoc:44
msgid "Complete an activity or exercise"
msgstr "Complete una actividad o ejercicio"

#. type: Plain text
#: en/data-use/modules/ROOT/pages/navigation.adoc:46
msgid "Discuss with your peers"
msgstr "Debate con sus compañeros"

