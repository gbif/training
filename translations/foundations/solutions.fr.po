msgstr ""

#. type: Plain text
#: en/foundations/modules/ROOT/pages/solutions.adoc:83
#, no-wrap
msgid "High accuracy, low precision\n"
"*C*"
msgstr "Haute exactitude, faible précision + *C*"

#. type: Plain text
#: en/foundations/modules/ROOT/pages/solutions.adoc:85
#, no-wrap
msgid "Low accuracy, high precision\n"
"*B*"
msgstr "Faible exactitude, haute précision + *B*"

#. type: Plain text
#: en/foundations/modules/ROOT/pages/solutions.adoc:87
#, no-wrap
msgid "High accuracy, high precision\n"
"*D*"
msgstr "Haute exactitude, haute précision + *D*"

#. type: Plain text
#: en/foundations/modules/ROOT/pages/solutions.adoc:89
#, no-wrap
msgid "Low accuracy, low precision\n"
"*A*"
msgstr "Faible exactitude, faible précision + *A*"

#. type: Plain text
#: en/foundations/modules/ROOT/pages/solutions.adoc:91
#, no-wrap
msgid "*Identify the data relationships where Dataset B needs to be merged into Dataset A (0:1, 1:0, 1:1, 1:∞, ∞:1, ∞:∞). Not all the relationships used.*\n"
msgstr "*Identifier les relations de données où l'ensemble de données B doit être fusionné avec l'ensemble de données A (0:1, 1:0, 1:1, 1:∞ , ∞ :1, ∞ :∞ ). Toutes les relations ne sont pas utilisées.*\n"

#. type: Plain text
#: en/foundations/modules/ROOT/pages/solutions.adoc:94
#, no-wrap
msgid "Collector field exists in both dataset A and B\n"
"*1:1*"
msgstr "Le champ Collector existe dans l'ensemble de données A et B + *1:1*"

#. type: Plain text
#: en/foundations/modules/ROOT/pages/solutions.adoc:96
#, no-wrap
msgid "Country field only exists in dataset B\n"
"*0:1*"
msgstr "Le champ pays n'existe que dans l'ensemble de données B + *0:1*"

#. type: Plain text
#: en/foundations/modules/ROOT/pages/solutions.adoc:98
#, no-wrap
msgid "Name field exists in dataset A, but dataset B contains First Name and Last Name fields\n"
"*1:∞*"
msgstr "Le champ nom existe dans l'ensemble de données A, mais l'ensemble de données B contient les champs Prénom et Nom + *1:∞*"

#. type: Plain text
#: en/foundations/modules/ROOT/pages/solutions.adoc:100
#, no-wrap
msgid "ID field exists in both dataset A and B\n"
"*1:1*"
msgstr "Le champ ID existe dans l'ensemble de données A et B + *1:1*"

#. type: Plain text
#: en/foundations/modules/ROOT/pages/solutions.adoc:102
#, no-wrap
msgid "Elevation exists in dataset A, but not in dataset B\n"
"*1:0*"
msgstr "L'élévation existe dans l'ensemble de données A, mais pas dans l'ensemble de données B + *1:0*"

#. type: Plain text
#: en/foundations/modules/ROOT/pages/solutions.adoc:104
#, no-wrap
msgid "Date exists in dataset A, but Day, Month, and Year are separate fields in dataset B\n"
"*1:∞*"
msgstr "La Date existe dans l'ensemble de données A, mais le Jour, le Mois et l'Année sont des champs séparés dans l'ensemble de données B + *1:∞*"

#. type: Plain text
#: en/foundations/modules/ROOT/pages/solutions.adoc:106
#, no-wrap
msgid "*Metadata is important because (select the TRUE statements)*\n"
msgstr "*Les métadonnées sont importantes car (sélectionnez les affirmations qui sont VRAIES)*\n"

#. type: Plain text
#: en/foundations/modules/ROOT/pages/solutions.adoc:108
msgid "it allows users to determine if a dataset is fit for their use."
msgstr "elles permettent aux utilisateurs de déterminer si un ensemble de données convient à leur utilisation."

#. type: Plain text
#: en/foundations/modules/ROOT/pages/solutions.adoc:108
msgid "it allows you to know under which legal terms the reuse of data is permitted."
msgstr "elles vous permettent de savoir sous quelles conditions légales la réutilisation des données est autorisée."

