#: en/data-mobilization/modules/ROOT/pages/management.adoc:232
#, no-wrap
msgid "Data management tools"
msgstr ""

#. type: delimited block =
#: en/data-mobilization/modules/ROOT/pages/management.adoc:237
msgid "In this presentation, you will learn about a variety of tools that you can use to improve the quality of your data."
msgstr ""

#. type: delimited block +
#: en/data-mobilization/modules/ROOT/pages/management.adoc:245
#, no-wrap
