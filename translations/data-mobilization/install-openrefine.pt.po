msgid "Installation on Mac"
msgstr "Instalação no Mac"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/install-openrefine.adoc:86
msgid "Download the https://github.com/OpenRefine/OpenRefine/releases/download/3.4.1/openrefine-mac-3.4.1.dmg[Mac kit]."
msgstr "Transfira o https://github.com/OpenRefine/OpenRefine/releases/download/3.4.1/openrefine-mac-3.4.1.dmg[Mac kit]."

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/install-openrefine.adoc:88
