#. type: Title ==
#: en/data-mobilization/modules/ROOT/pages/install-openrefine.adoc:196
#, no-wrap
msgid "Installation on Linux"
msgstr "Instalação no Linux"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/install-openrefine.adoc:199
msgid "Download the https://github.com/OpenRefine/OpenRefine/releases/download/3.4.1/openrefine-linux-3.4.1.tar.gz[Linux kit]."
msgstr "Transfira o https://github.com/OpenRefine/OpenRefine/releases/download/3.4.1/openrefine-linux-3.4.1.tar.gz[Linux kit]."

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/install-openrefine.adoc:201
msgid "Download, extract, then type ./refine to start.  This requires Java to be installed on your computer."
msgstr "Descarregue, extraia, em seguida digite ./refine para iniciar. Este requer que o Java esteja instalado no seu computador."

#. type: Block title
#: en/data-mobilization/modules/ROOT/pages/install-openrefine.adoc:202
#, no-wrap
msgid "Detailed instructions for Linux (click to expand)"
msgstr "Instruções detalhadas para Linux (clique para expandir)"

#. type: delimited block =
#: en/data-mobilization/modules/ROOT/pages/install-openrefine.adoc:206
msgid "These instructions are for KDE (e.g. Kubuntu, SuSE), but the process is similar for Gnome (e.g. Ubuntu, Red Hat, CentOS)."
msgstr "Estas instruções são para o KDE (por exemplo, Kubuntu, SuSE), mas o processo é similar para Gnome (por exemplo, Ubuntu, Red Hat, CentOS)."

#. type: Target for macro image
#: en/data-mobilization/modules/ROOT/pages/install-openrefine.adoc:212
#, no-wrap
msgid "data-mobilization::kde1-download-open.png"
msgstr ""

#. type: delimited block =
#: en/data-mobilization/modules/ROOT/pages/install-openrefine.adoc:214
msgid "Download the https://github.com/OpenRefine/OpenRefine/releases/download/3.4.1/openrefine-linux-3.4.1.tar.gz[Linux kit].  Open it."
msgstr "Transfira o https://github.com/OpenRefine/OpenRefine/releases/download/3.4.1/openrefine-linux-3.4.1.tar.gz[Linux kit]. Abra-o."

#. type: Target for macro image
#: en/data-mobilization/modules/ROOT/pages/install-openrefine.adoc:221
#, no-wrap
msgid "data-mobilization::kde2-extract.png"
msgstr ""

#. type: delimited block =
