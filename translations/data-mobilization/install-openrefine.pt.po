msgid "data-mobilization::kde4-open.png"
msgstr ""

#. type: delimited block =
#: en/data-mobilization/modules/ROOT/pages/install-openrefine.adoc:241
msgid "Right click \"refine\" and choose \"Run in Konsole\".  This is needed so you can safely exit OpenRefine later, by closing the Konsole window."
msgstr "Clique com o botão direito em \"refine\" e escolha \"Executar em Konsole\". Isso é necessário para possa sair do OpenRefine mais tarde, fechando a janela do Konsole."

