#, no-wrap
msgid "https://www.gbif.org/occurrence/6133453758[Calliostoma canaliculatum (Lightfoot) 1786^] observed in United States of America by Sheldon Logan (licensed under http://creativecommons.org/licenses/by-nc/4.0/[CC-BY-NC 4.0])"
msgstr ""

#. type: Target for macro image
#: en/data-mobilization/modules/ROOT/pages/use-case-marine.adoc:12
#, no-wrap
msgid "data-mobilization::UC-MS-Calliostoma-canaliculatum.png"
