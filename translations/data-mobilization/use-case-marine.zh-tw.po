#: en/data-mobilization/modules/ROOT/pages/use-case-marine.adoc:43
#, no-wrap
msgid "Figure 2a. Data tables from Gilman and Sagarin (1993) showing counts of 97 species across 19 quadrats that were sampled along Hewatt’s transect. The tables show Hewatt’s data (white) and their data (shaded), with totals at the right. "
msgstr ""

#. type: Target for macro image
#: en/data-mobilization/modules/ROOT/pages/use-case-marine.adoc:44
#, no-wrap
msgid "data-mobilization::MS-Figure2a.png"
msgstr ""

#. type: Block title
#: en/data-mobilization/modules/ROOT/pages/use-case-marine.adoc:47
#, no-wrap
msgid "Figure 2b. Data tables from Gilman and Sagarin (1993) showing counts of 97 species across 19 quadrats that were sampled along Hewatt’s transect. The tables show Hewatt’s data (white) and their data (shaded), with totals at the right."
msgstr ""

