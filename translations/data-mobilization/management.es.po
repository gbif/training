#, no-wrap
msgid "Exercise 2b"
msgstr ""

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:456
#, no-wrap
msgid "*Other data management tools*\n"
msgstr "*Otras herramientas de gestión de datos*\n"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:458
msgid "SBN has given you a checklist of data quality elements to verify:"
msgstr ""

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:460
msgid "All names (full name) are correctly spelled"
msgstr ""

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:461
msgid "All names belong to the order"
msgstr ""

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:462
msgid "All records have coordinates"
msgstr "Todos los registros tienen coordenadas"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:463
msgid "All coordinates are inside the country stated and converted to decimal format"
msgstr "Todas las coordenadas están dentro del país indicado y convertidas a formato decimal"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:464
msgid "All dates are in the proper column and in the format YYYY-MM-DD"
msgstr "Todas las fechas están en la columna correspondiente y en el formato AAAA-MM-DD"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:466
msgid "The three categories of errors are:"
msgstr "Las tres categorías de errores son:"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:468
msgid "Nomenclatural errors"
msgstr "Errores de nomenclatura"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:469
msgid "Format errors"
msgstr "Errores de formato"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:470
msgid "Geographic errors / outliers"
msgstr "Errores geográficos / valores atípicos"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:473
msgid "Refer to <<Helpful tools>> in order to complete the exercise.  You are not limited to these tools, you may use any tools you like."
msgstr "Consulte <<Herramientas útiles>> para completar el ejercicio. No está limitado a estas herramientas, puede utilizar cualquier herramienta que desee."

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:474
msgid "Use the same file from the previous exercise."
msgstr "Utilice el mismo archivo del ejercicio anterior."

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:475
msgid "Make the correction ONLY for the ?? family (so you may want to filter the data)"
msgstr ""

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:476
msgid "Correct the errors found in the dataset used in exercise 2a (previous exercise), using the tools of your choice, and document the changes you perform in the exercise sheet."
msgstr ""

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:477
msgid "Correct the entire file if you have time."
msgstr "Corrija todo el archivo si tiene tiempo."

#. type: delimited block =
#: en/data-mobilization/modules/ROOT/pages/management.adoc:484
