msgstr "*Controles de validación*\n"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:445
msgid "In this exercise we will focus on technical errors and perform a basic validation check to identify technical errors."
msgstr ""

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:447
msgid "Refer to <<Validation checks>> for information on the types of errors."
msgstr ""

