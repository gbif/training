#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:58
#, no-wrap
msgid "*Other data management tools*\n"
msgstr "*Otras herramientas de gestión de datos*\n"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:60
msgid "The GPA association has given you a checklist of data quality elements to verify:"
msgstr "La asociación GPA le ha proporcionado una lista de elementos de calidad de datos que debe verificar:"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:62
msgid "All plant names (full name) are correctly spelled"
msgstr "Todos los nombres de las plantas (nombre completo) están escritos correctamente"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:63
msgid "All plant names belong to the order"
msgstr "Todos los nombres de las plantas pertenecen al pedido"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:64
msgid "All records have coordinates"
msgstr "Todos los registros tienen coordenadas"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:65
msgid "All coordinates are inside the country stated and converted to decimal format"
msgstr "Todas las coordenadas están dentro del país indicado y convertidas a formato decimal"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:66
msgid "All dates are in the proper column and in the format YYYY-MM-DD"
msgstr "Todas las fechas están en la columna correspondiente y en el formato AAAA-MM-DD"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:68
msgid "The three categories of errors are:"
msgstr "Las tres categorías de errores son:"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:70
msgid "Nomenclatural errors"
msgstr "Errores de nomenclatura"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:71
msgid "Format errors"
msgstr "Errores de formato"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:72
msgid "Geographic errors / outliers"
msgstr "Errores geográficos / valores atípicos"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:75
msgid "Refer to <<Helpful tools>> in order to complete the exercise.  You are not limited to these tools, you may use any tools you like."
msgstr "Consulte <<Herramientas útiles>> para completar el ejercicio. No está limitado a estas herramientas, puede utilizar cualquier herramienta que desee."

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:76
msgid "Use the same file from the previous exercise."
msgstr "Utilice el mismo archivo del ejercicio anterior."

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:77
msgid "Make the correction ONLY for the Eriocaulaceae family (so you may want to filter the data)"
msgstr "Haga la corrección SOLO para la familia Eriocaulaceae (por lo que puede querer filtrar los datos)"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:78
msgid "Correct the errors found in the dataset used in exercise 3a (previous exercise), using the tools of your choice, and document the changes you perform in the exercise sheet."
msgstr "Corrija los errores encontrados en el conjunto de datos usado en el ejercicio 3a (ejercicio anterior), usando las herramientas de su elección, y documente los cambios que realiza en la hoja de ejercicio."

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/management.adoc:79
msgid "Correct the entire file if you have time."
msgstr "Corrija todo el archivo si tiene tiempo."

