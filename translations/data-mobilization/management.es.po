#. type: delimited block =
#: en/data-mobilization/modules/ROOT/pages/management.adoc:40
#, no-wrap
msgid "*Slide 1 - Data management*\n"
msgstr "*Diapositiva 1 - Gestión de Datos*\n"

#. type: delimited block =
#: en/data-mobilization/modules/ROOT/pages/management.adoc:42
msgid "In this presentation, we are going to explore the key principles and processes important to effective data management."
msgstr "En esta presentación, vamos a explorar los principios y procesos clave que son importantes para una gestión de datos eficaz."

#. type: delimited block =
#: en/data-mobilization/modules/ROOT/pages/management.adoc:49
msgid "Photo: GBIF: https://www.gbif.org/occurrence/2597778861 Passiflora miniata Vanderpl.  Rights holder: Gee (Gerard Chartier)  License: http://creativecommons.org/licenses/by/4.0/ Reference: https://www.flickr.com/photos/33212211@N00/49747811713/"
