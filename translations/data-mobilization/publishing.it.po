#, no-wrap
msgid "*Data publishing*\n"
msgstr ""

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/publishing.adoc:250
msgid "After cleaning the data in the dataset, the team considers that publishing the data online through GBIF could be a good way to make this effort visible. You have been requested to lead that publishing work."
msgstr ""

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/publishing.adoc:252
msgid "Download xref:attachment$UC-Practice-3-ForPublication.xlsx[UC-Practice-3-ForPublication.xlsx,opts=download]. (57 KB)"
