#, no-wrap
msgid "Learning objectives"
msgstr "Obiettivi di apprendimento"

#. type: delimited block =
#: en/data-mobilization/modules/ROOT/pages/description.adoc:49
msgid "Learn key concepts (foundations) of biodiversity informatics, particular to biodiversity digital data management."
msgstr ""

#. type: delimited block =
#: en/data-mobilization/modules/ROOT/pages/description.adoc:50
msgid "Receive an introduction to the Darwin Core Standard and its components."
msgstr ""

#. type: delimited block =
#: en/data-mobilization/modules/ROOT/pages/description.adoc:51
msgid "Learn to identify the types of data and how to best capture relevant information using best practices, existing softwares, tools and techniques."
msgstr ""

#. type: delimited block =
#: en/data-mobilization/modules/ROOT/pages/description.adoc:52
msgid "Use software tools designed to facilitate biodiversity data capture to produce digital biodiversity data from analogue sources."
msgstr ""

#. type: delimited block =
#: en/data-mobilization/modules/ROOT/pages/description.adoc:53
msgid "Learn data quality concepts and receive an introduction to tools used for standardizing data, validating data, and cleaning data."
msgstr ""

#. type: delimited block =
#: en/data-mobilization/modules/ROOT/pages/description.adoc:54
msgid "Use software tools to evaluate the fitness-for-use of a biodiversity dataset"
msgstr ""

#. type: delimited block =
#: en/data-mobilization/modules/ROOT/pages/description.adoc:55
msgid "Use software tools designed for (biodiversity) data cleaning."
msgstr ""

#. type: delimited block =
#: en/data-mobilization/modules/ROOT/pages/description.adoc:56
msgid "Learn the process of making biodiversity data freely available online, also known as data publishing, utilizing GBIF’s Integrated Publishing Toolkit (IPT)."
msgstr ""

#. type: delimited block =
#: en/data-mobilization/modules/ROOT/pages/description.adoc:57
msgid "Define the publishable data types and subtypes (if any) for a biodiversity dataset."
msgstr ""

#. type: delimited block =
#: en/data-mobilization/modules/ROOT/pages/description.adoc:58
msgid "Use the GBIF IPT to publish biodiversity datasets using the appropriate extensions."
msgstr ""

