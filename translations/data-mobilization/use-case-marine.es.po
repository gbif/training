#. type: Title ===
#: en/data-mobilization/modules/ROOT/pages/use-case-marine.adoc:54
#, no-wrap
msgid "Data conversion and aggregation"
msgstr "Conversión y agregación de datos"

#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/use-case-marine.adoc:57
msgid "Both Hewatt and Gilman/Sagarin recorded data in a table format for species for each transect. These “lists” were converted into a format aligned to an occurrence dataset(Figures 3 and 4)."
msgstr "Tanto Hewatt como Gilman/Sagarin registraron los datos de cada transecta en forma de tabla. Estas \"listas\" se convirtieron a un formato alineado con un conjunto de datos de registros biológicos (Figuras 3 y 4)."

#. type: Block title
#: en/data-mobilization/modules/ROOT/pages/use-case-marine.adoc:59
#, no-wrap
msgid "Figure 3. Hewatt’s data transcribed into a spreadsheet. This is a critical first step, but this is not a data layout that will work for upload to taxonomic databases."
msgstr "Figura 3. Los datos de Hewatt transcritos a una hoja de cálculo. Se trata de un primer paso fundamental, pero no es un diseño de datos que sirva para cargarlos en bases de datos taxonómicas."

#. type: Target for macro image
#: en/data-mobilization/modules/ROOT/pages/use-case-marine.adoc:60
#, no-wrap
msgid "data-mobilization::MS-Figure3.png"
msgstr "data-mobilization::MS-Figure3.png"

#. type: Block title
#: en/data-mobilization/modules/ROOT/pages/use-case-marine.adoc:63
#, no-wrap
msgid "Figure 4. Hewatt’s data converted to a format aligned to an occurrence dataset. Some information has been pulled from the thesis to start to build out each occurrence record."
msgstr "Figura 4. Datos de Hewatt convertidos a un formato acorde con un conjunto de datos de registros de biodiversidad. Se ha extraído parte de la información de la tesis para empezar a construir cada registro."

#. type: Target for macro image
#: en/data-mobilization/modules/ROOT/pages/use-case-marine.adoc:64
#, no-wrap
msgid "data-mobilization::MS-Figure4.png"
msgstr "data-mobilization::MS-Figure4.png"

