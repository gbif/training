#.  Question 2
#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/publishing.adoc:97
msgid "What is an IPT?"
msgstr ""

#. type: delimited block .
#: en/data-mobilization/modules/ROOT/pages/publishing.adoc:103
#, no-wrap
msgid "- [ ] a tool that helps you manage & correct your data\n"
"- [x] a tool that helps you publish your data to GBIF\n"
"- [x] a tool that helps you produce a Data paper\n"
msgstr ""

#.  Question 3
#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/publishing.adoc:106
msgid "Which Creative Commons licences and waivers are recommended by GBIF for data publication?"
msgstr ""

#. type: delimited block .
#: en/data-mobilization/modules/ROOT/pages/publishing.adoc:112
#, no-wrap
msgid "- [ ] CC-BY, CC-BY-SA and CC-BY-ND\n"
"- [x] CC0, CC-BY and CC-BY-NC\n"
"- [ ] CC0, CC-BY and CC-BY-SA\n"
msgstr ""

#.  Question 4
#. type: Plain text
#: en/data-mobilization/modules/ROOT/pages/publishing.adoc:115
