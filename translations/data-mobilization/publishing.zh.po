msgstr ""

#. type: delimited block .
#: en/data-mobilization/modules/ROOT/pages/publishing.adoc:121
#, no-wrap
msgid "- [ ] Metadata Core, Occurrence Core, Multimedia Core\n"
"- [ ] Taxon Core, Collection Core, MeasurementOrFact Core\n"
"- [x] Occurrence Core, Taxon Core, Event Core\n"
msgstr ""

