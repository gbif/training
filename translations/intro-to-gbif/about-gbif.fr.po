#: en/intro-to-gbif/modules/ROOT/pages/about-gbif.adoc:165
#, no-wrap
msgid "- [x] The Head of Delegation\n"
"- [ ] The GBIF Secretariat\n"
msgstr "- [x] Le Responsable de Délégation\n"
"- [ ] Le Secrétariat du GBIF\n"

